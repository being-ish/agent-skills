{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/scripts/remind-skill.sh\"",
            "statusMessage": "スタイルガイドを確認中",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/scripts/check-writing.sh\"",
            "statusMessage": "書き方をチェック中",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
